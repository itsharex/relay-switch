{
  "name": "relay-switch",
  "private": true,
  "version": "2.0.6",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter desktop dev",
    "dev:web": "node scripts/dev-web.mjs",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build",
    "web:preview": "pnpm --filter web preview",
    "server:package": "node scripts/package-server-release.mjs",
    "validate:model-presets": "node scripts/validate-model-presets.mjs",
    "validate:provider-presets": "node scripts/validate-provider-presets.mjs",
    "build": "pnpm --filter desktop build",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build",
    "docs:preview": "pnpm --filter docs preview"
  },
  "devDependencies": {
    "@relay-switch/presets": "workspace:*"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
